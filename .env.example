# ---------- Syncplay image ----------
SYNCPLAY_IMAGE=ghcr.io/rezarajan/syncplay-tailscale:latest

# ---------- Syncplay app config ----------
SYNCPLAY_PORT=8999
SYNCPLAY_PASSWORD=change-this
SYNCPLAY_SALT=replace-with-a-long-random-string
SYNCPLAY_ISOLATE_ROOM=false
SYNCPLAY_DISABLE_READY=false
SYNCPLAY_DISABLE_CHAT=false

# Leave blank unless you need them
SYNCPLAY_MAX_CHAT_MESSAGE_LENGTH=
SYNCPLAY_MAX_USERNAME_LENGTH=
SYNCPLAY_MOTD_FILE=
SYNCPLAY_STATS_DB_FILE=
SYNCPLAY_TLS_PATH=

# ---------- Tailscale sidecar config ----------
# Create this in the Tailscale admin console.
TS_AUTHKEY=tskey-xxxxxxxxxxxxxxxx

# Tailnet hostname for this node.
TS_HOSTNAME=syncplay

# Optional extra args, for example:
# --advertise-tags=tag:media
TS_EXTRA_ARGS=
